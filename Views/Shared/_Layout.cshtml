<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TwoFactorAuthApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TwoFactorAuthApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Register">
                    <i class="bi bi-shield-check"></i> TwoFactorAuthApp
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-shield-lock"></i> 2FA Methods
                            </a>
                            <ul class="dropdown-menu">
                                <li><h6 class="dropdown-header"><i class="bi bi-google text-primary"></i> Google Authenticator</h6></li>
                                <li><a class="dropdown-item" asp-controller="Home" asp-action="Register">Register</a></li>
                                <li><a class="dropdown-item" asp-controller="Home" asp-action="Login">Login</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><h6 class="dropdown-header"><i class="bi bi-envelope text-success"></i> Email-Based 2FA</h6></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Register">Register</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Login">Login</a></li>
                            </ul>
                        </li>
                    </ul>

                    <!-- Login/Logout based on session (handles both auth methods) -->
                    <ul class="navbar-nav">
                        @{
                            // Check Google Auth session
                            var googleUser = Context.Session.GetString("CurrentUser");
                            var google2FA = Context.Session.GetString("TwoFactorPassed");
                            var isGoogleLoggedIn = !string.IsNullOrEmpty(googleUser) && google2FA == "yes";

                            // Check Email Auth session
                            var emailUser = Context.Session.GetString("AccountUser");
                            var email2FA = Context.Session.GetString("Account2FAPassed");
                            var isEmailLoggedIn = !string.IsNullOrEmpty(emailUser) && email2FA == "yes";
                        }
                        @if (isGoogleLoggedIn)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-primary fw-bold">
                                    <i class="bi bi-google"></i> @googleUser
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-action="Logout" asp-controller="Home">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </li>
                        }
                        else if (isEmailLoggedIn)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-success fw-bold">
                                    <i class="bi bi-envelope"></i> @emailUser
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-action="Logout" asp-controller="Account">
                                    <i class="bi bi-box-arrow-right"></i> Logout
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-box-arrow-in-right"></i> Login
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Home" asp-action="Login"><i class="bi bi-google text-primary"></i> Google Auth 2FA</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Login"><i class="bi bi-envelope text-success"></i> Email 2FA</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container text-center">
            <span>Cloud Computing - Lab 11: Two-Factor Authentication using Google Authenticator &amp; Email 2FA</span><br />
            <small>Khizar | Enrollment: 02-131232-064 | &copy; 2026</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
