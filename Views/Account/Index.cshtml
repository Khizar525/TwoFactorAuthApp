@{
    ViewData["Title"] = "Email 2FA - Home";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 text-center">
        <div class="mb-4">
            <i class="bi bi-envelope-check" style="font-size: 4rem; color: #198754;"></i>
        </div>

        <h1 class="display-4 fw-bold text-success mb-3">
            Welcome, @ViewBag.Username!
        </h1>

        <p class="lead mb-4">
            You have successfully logged in with
            <span class="fw-bold">Email-Based Two-Factor Authentication</span>.
        </p>

        <div class="alert alert-success text-start d-inline-block mx-auto">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill fs-3 me-3"></i>
                <div>
                    <strong>2FA Status:</strong> Authenticated via Email Code<br />
                    <span class="small">Your identity has been verified using two factors: password + email verification code.</span>
                </div>
            </div>
        </div>

        <div class="mt-4 p-4 bg-light rounded-3 text-start">
            <h5><i class="bi bi-info-circle"></i> Session Info</h5>
            <table class="table table-sm table-borderless mb-0">
                <tr>
                    <td class="fw-bold" style="width: 140px;">Username:</td>
                    <td>@ViewBag.Username</td>
                </tr>
                <tr>
                    <td class="fw-bold">Auth Method:</td>
                    <td>Password + Email Verification Code</td>
                </tr>
                <tr>
                    <td class="fw-bold">Session Status:</td>
                    <td><span class="badge bg-success">Active</span></td>
                </tr>
            </table>
        </div>

        <div class="mt-4">
            <a asp-action="Logout" class="btn btn-outline-danger btn-lg px-5">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>
    </div>
</div>
