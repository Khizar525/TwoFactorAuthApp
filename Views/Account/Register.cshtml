@model RegisterModel
@{
    ViewData["Title"] = "Register (Email 2FA)";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-success text-white text-center py-4 rounded-top-4">
                <h3 class="mb-0"><i class="bi bi-envelope-plus-fill"></i> Register — Email 2FA</h3>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-info small mb-4">
                    <i class="bi bi-info-circle"></i>
                    This registration is for <strong>Email-Based 2FA</strong>.
                    You will receive a verification code via email during login.
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div class="alert alert-danger">@error.ErrorMessage</div>
                    }
                }

                <form asp-action="Register" method="post">
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label fw-bold">Username</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="UserName" class="form-control" placeholder="Choose a username" />
                        </div>
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-bold">Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Password" class="form-control" placeholder="Min 6 characters" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-bold">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Re-enter password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-2 fw-bold">
                        <i class="bi bi-person-check"></i> Register
                    </button>
                </form>

                <hr class="my-4" />
                <p class="text-center mb-0">
                    Already have an account?
                    <a asp-action="Login" class="fw-bold text-decoration-none">Login here</a>
                </p>
                <p class="text-center small mt-2">
                    <a asp-controller="Home" asp-action="Register" class="text-decoration-none">
                        Switch to Google Authenticator 2FA
                    </a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
