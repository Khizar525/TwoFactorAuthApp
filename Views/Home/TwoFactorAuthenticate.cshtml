@model TwoFactorModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-header bg-info text-white text-center py-4 rounded-top-4">
                <h3 class="mb-0"><i class="bi bi-shield-lock-fill"></i> Two-Factor Authentication</h3>
            </div>
            <div class="card-body p-4 text-center">

                @if (!string.IsNullOrEmpty(ViewBag.Message))
                {
                    <div class="alert alert-danger">@ViewBag.Message</div>
                }

                <div class="mb-3">
                    <i class="bi bi-phone" style="font-size: 2.5rem; color: #0dcaf0;"></i>
                </div>

                <h5 class="mb-3">Scan with Google Authenticator</h5>
                <p class="text-muted small mb-4">
                    Open the Google Authenticator app on your mobile device
                    and scan the QR code below.
                </p>

                @if (!string.IsNullOrEmpty(Model.QrCodeImage))
                {
                    <div class="mb-3 p-3 bg-light rounded-3 d-inline-block">
                        <img src="@Model.QrCodeImage" alt="QR Code" class="img-fluid"
                             style="max-width: 220px; image-rendering: pixelated;" />
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.ManualEntryKey))
                {
                    <p class="text-muted small mb-3">
                        Or enter setup key manually:
                        <br />
                        <strong class="text-info" style="font-size: 0.85rem; word-break: break-all;">
                            @Model.ManualEntryKey
                        </strong>
                    </p>
                }

                <hr class="my-4" />

                <h5 class="mb-3">Enter Verification Code</h5>
                <p class="text-muted small mb-3">
                    Enter the 6-digit code from your authenticator app:
                </p>

                <form asp-action="VerifyTwoFactor" method="post">
                    <div class="mb-3">
                        <input asp-for="Code" class="form-control text-center form-control-lg mx-auto"
                               style="max-width: 200px; font-size: 1.5rem; letter-spacing: 6px;"
                               placeholder="000000" maxlength="6" inputmode="numeric"
                               pattern="[0-9]*" autocomplete="off" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-info text-white w-100 py-2 fw-bold">
                        <i class="bi bi-check-circle"></i> Verify & Login
                    </button>
                </form>

                <div class="mt-3">
                    <a asp-action="Login" class="text-decoration-none small">
                        <i class="bi bi-arrow-left"></i> Back to Login
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
